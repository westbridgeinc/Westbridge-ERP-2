{
  "name": "westbridge-erp-backend",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:load:smoke": "k6 run load-tests/smoke.js",
    "test:load": "k6 run load-tests/average-load.js",
    "test:load:stress": "k6 run load-tests/stress.js",
    "test:load:spike": "k6 run load-tests/spike.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@prisma/client": "^6.4.1",
    "@sentry/node": "^9.5.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.40.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^10.4.3",
    "pino": "^10.3.1",
    "posthog-node": "^4.18.0",
    "prom-client": "^15.1.3",
    "resend": "^6.4.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.4.0",
    "@types/pino": "^7.0.5",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@eslint/js": "^9.21.0",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.21.0",
    "prisma": "^6.4.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^4.0.18"
  }
}
