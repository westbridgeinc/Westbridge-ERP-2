# ──────────────────────────────────────────────────────────────────────────────
# Westbridge ERP Backend — Production Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file and fill in real values before deploying.
# For Fly.io: use `fly secrets set KEY=VALUE` instead of a .env file.
# Generate secrets with: openssl rand -hex 32
# ──────────────────────────────────────────────────────────────────────────────

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000

# ── Database (auto-set by `fly postgres attach`) ─────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/westbridge?schema=public

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Security (REQUIRED — server refuses to start with defaults) ──────────────
SESSION_SECRET=   # openssl rand -hex 32
CSRF_SECRET=      # openssl rand -hex 32
ENCRYPTION_KEY=   # openssl rand -hex 32

# ── Frontend URLs ────────────────────────────────────────────────────────────
FRONTEND_URL=https://app.westbridge.app
NEXT_PUBLIC_APP_URL=https://app.westbridge.app

# ── ERPNext ──────────────────────────────────────────────────────────────────
ERPNEXT_URL=https://your-erpnext-instance.com
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxx
EMAIL_FROM=Westbridge <noreply@westbridge.app>

# ── AI (Anthropic Claude) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ── Billing (PowerTranz — Caribbean payment gateway) ──────────────────────
POWERTRANZ_ID=              # PowerTranz merchant ID
POWERTRANZ_PASSWORD=        # PowerTranz merchant password
POWERTRANZ_TEST_MODE=false  # "true" for staging, "false" for production

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
POSTHOG_API_KEY=
LOG_LEVEL=info

# ── Cookies ──────────────────────────────────────────────────────────────────
COOKIE_SAME_SITE=none
