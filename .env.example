# ═══════════════════════════════════════════════════════════
# Westbridge Backend — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy to .env and fill in values.
# Generate secrets: openssl rand -hex 32

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/westbridge?schema=public"

# ─── Docker Compose Service Passwords ─────────────────────
# Required when using docker-compose.yml (generate with: openssl rand -hex 16)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
REDIS_PASSWORD=
MARIADB_ROOT_PASSWORD=
ERPNEXT_ADMIN_PASSWORD=

# ─── Redis ────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ─── Security (REQUIRED — generate with: openssl rand -hex 32) ─
SESSION_SECRET="change-me-in-production"
CSRF_SECRET="change-me-in-production"
ENCRYPTION_KEY="change-me-in-production"

# Key rotation (set previous key here when rotating)
CSRF_SECRET_PREVIOUS=""
ENCRYPTION_KEY_PREVIOUS=""

# ─── ERPNext ──────────────────────────────────────────────
ERPNEXT_URL="http://localhost:8080"
ERPNEXT_API_KEY=""
ERPNEXT_API_SECRET=""

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@westbridge.gy"

# ─── AI ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=""

# ─── Billing (PowerTranz) ────────────────────────────────
POWERTRANZ_ID=""
POWERTRANZ_PASSWORD=""
POWERTRANZ_TEST_MODE="true"

# ─── Observability ────────────────────────────────────────
SENTRY_DSN=""
POSTHOG_API_KEY=""
POSTHOG_HOST=""
LOG_LEVEL=info

# ─── Caribbean Defaults (baked into code) ─────────────────
# DEFAULT_CURRENCY=GYD
# VAT_RATE=0.14
# NIS_EMPLOYER_RATE=0.088
# NIS_EMPLOYEE_RATE=0.056
# NIS_CEILING=280000
# PAYE_THRESHOLD=780000
# WITHHOLDING_TAX_RATE=0.20
